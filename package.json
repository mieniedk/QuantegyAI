{
  "name": "quantegyai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:open": "vite --open",
    "server": "node server/index.js",
    "start": "concurrently --kill-others \"node server/index.js\" \"vite\"",
    "start:prod": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "backup:data": "node scripts/backup-data.mjs",
    "restore:data": "node scripts/restore-data.mjs",
    "restore:verify": "node scripts/verify-restore.mjs",
    "loadtest:api": "node scripts/loadtest-api.mjs",
    "test": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:api:security": "vitest run tests/api/lti-admin-auth.test.mjs tests/api/onboarding.test.mjs",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "qa:bingo": "node scripts/validate-bingo-content.mjs",
    "e2e": "playwright test",
    "e2e:mastery": "playwright test tests/e2e/mastery-admin.spec.mjs tests/e2e/mastery-admin-real.spec.mjs",
    "e2e:mastery:headed": "playwright test --headed tests/e2e/mastery-admin.spec.mjs tests/e2e/mastery-admin-real.spec.mjs",
    "e2e:onboarding": "playwright test tests/e2e/onboarding-wizard.spec.mjs",
    "e2e:accessibility": "playwright test tests/e2e/accessibility-smoke.spec.mjs",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dompurify": "^3.2.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.33",
    "multer": "^2.1.0",
    "nodemailer": "^8.0.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^7.13.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^17.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vitest": "^3.2.1",
    "vite": "^7.3.1"
  }
}
